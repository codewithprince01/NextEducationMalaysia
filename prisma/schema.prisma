generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model University {
  id                                    BigInt                                  @id @default(autoincrement()) @db.UnsignedBigInt
  name                                  String                                  @db.VarChar(100)
  uname                                 String                                  @db.VarChar(100)
  author_id                             BigInt?                                 @db.UnsignedBigInt
  website                               String                                  @default("MYS") @db.VarChar(10)
  code                                  String?                                 @db.VarChar(20)
  views                                 String?                                 @db.VarChar(10)
  state                                 String?                                 @db.VarChar(30)
  city                                  String?                                 @db.VarChar(30)
  rank                                  String?                                 @db.VarChar(10)
  qs_asia_rank                          String?                                 @db.VarChar(255)
  qs_rank                               String?                                 @db.VarChar(100)
  times_rank                            String?                                 @db.VarChar(100)
  shortnote                             String?                                 @db.LongText
  overview                              String?                                 @db.LongText
  institute_type_id                     BigInt?                                 @map("institute_type") @db.UnsignedBigInt
  instituteType                         InstituteType?                          @relation(fields: [institute_type_id], references: [id])
  established_year                      String?                                 @db.VarChar(20)
  email                                 String?                                 @db.VarChar(50)
  cc                                    String?                                 @db.Text
  loginid                               String?                                 @db.VarChar(20)
  mobile                                String?                                 @db.VarChar(20)
  ip                                    String?                                 @db.VarChar(50)
  login_count                           Int?
  click                                 Int?
  status                                Boolean?
  homeview                              Boolean?
  logo_path                             String?                                 @db.Text
  banner_path                           String?                                 @db.Text
  meta_title                            String?                                 @db.VarChar(100)
  meta_keyword                          String?                                 @db.Text
  meta_description                      String?                                 @db.LongText
  page_content                          String?                                 @db.VarChar(100)
  seo_rating                            BigInt?
  best_rating                           Decimal?                                @db.Decimal(2, 1)
  review_number                         Int?
  og_image_path                         String?                                 @db.Text
  last_login                            DateTime?                               @db.DateTime(0)
  ogimgname                             String?                                 @db.VarChar(100)
  ogimgpath                             String?                                 @db.VarChar(100)
  inst_type                             String?                                 @db.VarChar(20)
  imgname                               String?                                 @db.VarChar(100)
  imgpath                               String?                                 @db.VarChar(100)
  bannername                            String?                                 @db.VarChar(100)
  bannerpath                            String?                                 @db.VarChar(100)
  rating                                Float?                                  @db.Float
  partner                               Boolean?
  featured                              Boolean                                 @default(false)
  latitude_longitude                    String?                                 @db.VarChar(255)
  approved_by                           String?                                 @db.LongText
  accredited_by                         String?                                 @db.LongText
  hostel_facility                       String?                                 @db.LongText
  malaysia_rank                         String?                                 @db.VarChar(255)
  local_students                        Int?
  international_students                Int?
  contact_number1                       String?                                 @db.VarChar(255)
  contact_number2                       String?                                 @db.VarChar(255)
  is_local                              Boolean?
  is_international                      Boolean?
  study_options                         String?                                 @db.LongText
  created_at                            DateTime                                @default(now()) @db.Timestamp(0)
  updated_at                            DateTime                                @default(now()) @updatedAt @db.Timestamp(0)
  asign_review_category_to_universities asign_review_category_to_universities[]
  landing_page_universities             landing_page_universities[]
  reviews                               Review[]
  university_brochures                  university_brochures[]
  university_category_reviews           university_category_reviews[]
  university_contents                   university_contents[]
  facilities                            UniversityFacility[]
  university_features                   university_features[]
  university_fees                       university_fees[]
  university_level_and_course_fees      university_level_and_course_fees[]
  university_news                       university_news[]
  university_other_fees                 university_other_fees[]
  overviews                             UniversityOverview[]
  university_page_specializations       university_page_specializations[]
  photos                                UniversityPhoto[]
  programs                              UniversityProgram[]
  rankings                              UniversityRanking[]
  scholarships                          UniversityScholarship[]
  university_tution_fees                university_tution_fees[]
  videos                                UniversityVideo[]

  @@map("universities")
}

model UniversityProgram {
  id                               BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  course_name                      String                     @db.VarChar(100)
  university_id                    BigInt                     @db.UnsignedBigInt
  author_id                        BigInt?                    @db.UnsignedBigInt
  u_status                         Boolean                    @default(true)
  uname                            String?                    @db.VarChar(100)
  program_id                       BigInt?                    @db.UnsignedBigInt
  slug                             String                     @db.VarChar(100)
  course_category_id               BigInt                     @db.UnsignedBigInt
  course_category                  String?                    @db.VarChar(100)
  course_category_slug             String?                    @db.VarChar(100)
  specialization_id                BigInt?                    @db.UnsignedBigInt
  specialization                   String?                    @db.VarChar(100)
  specialization_slug              String?                    @db.VarChar(100)
  level                            String?                    @db.VarChar(100)
  duration                         String?                    @db.VarChar(50)
  study_mode                       String?                    @db.VarChar(200)
  intake                           String?                    @db.VarChar(100)
  application_deadline             String?                    @db.Text
  language                         String?                    @db.VarChar(20)
  scholarship                      String?                    @db.VarChar(20)
  tution_fee                       Int?
  overview                         String?                    @db.LongText
  status                           Boolean
  feefilename                      String?                    @db.VarChar(100)
  feefilepath                      String?                    @db.VarChar(100)
  application_fee                  Int?
  viza_fee                         Int?
  international_student_fee        Int?
  medical_insurance_fee            Int?
  personal_bond_fee                Int?
  library_fee                      Int?
  exam_fee                         Int?
  admin_fee                        Int?
  icard_fee                        Int?
  tutions_fee                      Int?
  fee_type                         String?                    @db.VarChar(100)
  fee_number                       String?                    @db.VarChar(10)
  other_fees                       Int?
  discount                         Int?
  commission                       Int?
  meta_title                       String?                    @db.VarChar(100)
  meta_description                 String?                    @db.LongText
  meta_keyword                     String?                    @db.LongText
  page_content                     String?                    @db.VarChar(100)
  seo_rating                       Decimal?                   @db.Decimal(2, 1)
  best_rating                      Decimal?                   @db.Decimal(2, 1)
  review_number                    Int?
  og_image_path                    String?                    @db.Text
  entry_requirement                String?                    @db.LongText
  exam_required                    String?                    @db.LongText
  mode_of_instruction              String?                    @db.Text
  scholarship_info                 String?                    @db.LongText
  avrg_tution_fees_per_year        String?                    @db.VarChar(100)
  avrg_cost_living_per_year        String?                    @db.VarChar(100)
  application_fees                 String?                    @db.VarChar(100)
  intake_deadline                  String?                    @db.VarChar(80)
  international_student_fees       String?                    @db.VarChar(50)
  fees_remark                      String?                    @db.Text
  domestic_discount                Int?
  international_discount           Int?
  saarc_discount                   Int?
  website                          String                     @default("MYS") @db.VarChar(10)
  nri_discount                     Int?
  total_fee                        Decimal?                   @db.Decimal(12, 2)
  total_tuition_fee                Decimal?                   @db.Decimal(12, 2)
  annual_tuition_fee               Decimal?                   @db.Decimal(12, 2)
  registration_fee                 Decimal?                   @db.Decimal(12, 2)
  laboratory_fee                   Decimal?                   @db.Decimal(12, 2)
  technology_fee                   Decimal?                   @db.Decimal(12, 2)
  student_activity_fee             Decimal?                   @db.Decimal(12, 2)
  insurance_fee                    Decimal?                   @db.Decimal(12, 2)
  examination_fee                  Decimal?                   @db.Decimal(12, 2)
  emgs_processing_fee              Decimal?                   @db.Decimal(12, 2)
  international_security_deposit   Decimal?                   @db.Decimal(12, 2)
  international_student_charge     Decimal?                   @db.Decimal(12, 2)
  international_administration_fee Decimal?                   @db.Decimal(12, 2)
  resources_fee                    Decimal?                   @db.Decimal(12, 2)
  commitment_fee                   Decimal?                   @db.Decimal(12, 2)
  facilities_fee                   Decimal?                   @db.Decimal(12, 2)
  other_fee                        Decimal?                   @db.Decimal(12, 2)
  scholarship_amount               Decimal?                   @db.Decimal(12, 2)
  tution_fee_after_scholarship     Decimal?                   @db.Decimal(12, 2)
  last_update                      DateTime?                  @db.Timestamp(0)
  currency                         String?                    @db.VarChar(10)
  additional_note                  String?                    @db.Text
  year1_tuition_fee                Decimal?                   @db.Decimal(12, 2)
  year2_tuition_fee                Decimal?                   @db.Decimal(12, 2)
  year3_tuition_fee                Decimal?                   @db.Decimal(12, 2)
  year4_tuition_fee                Decimal?                   @db.Decimal(12, 2)
  accommodation_fee                Decimal?                   @db.Decimal(12, 2)
  airport_pickup_fee               Decimal?                   @db.Decimal(12, 2)
  anual_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  year1_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  year2_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  year3_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  year4_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  total_tuition_fee_local          Decimal?                   @db.Decimal(12, 2)
  campus                           String?                    @db.Text
  accreditations                   String?                    @db.LongText
  is_local                         Boolean?                   @default(false)
  is_international                 Boolean?                   @default(false)
  created_at                       DateTime                   @default(now()) @db.Timestamp(0)
  updated_at                       DateTime?                  @default(now()) @updatedAt @db.Timestamp(0)
  student_applications             student_applications[]
  contents                         UniversityProgramContent[]
  university                       University                 @relation(fields: [university_id], references: [id], onDelete: Cascade, map: "university_programs_ibfk_1")
  courseCategory                   CourseCategory             @relation(fields: [course_category_id], references: [id], onDelete: Cascade, map: "university_programs_ibfk_2")
  courseSpecialization             CourseSpecialization?      @relation(fields: [specialization_id], references: [id], onUpdate: SetNull, map: "university_programs_ibfk_3")
  university_tution_fees           university_tution_fees[]

  @@index([university_id], map: "u_id")
  @@index([course_category_id], map: "university_programs_ibfk_2")
  @@index([specialization_id], map: "university_programs_ibfk_3")
  @@map("university_programs")
}

model CourseCategory {
  id                     BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  name                   String                   @db.VarChar(100)
  slug                   String                   @db.VarChar(100)
  shortnote              String?                  @db.Text
  author_id              BigInt?                  @db.UnsignedBigInt
  thumbnail_path         String?                  @db.Text
  banner_path            String?                  @db.Text
  content_image_name     String?                  @db.VarChar(200)
  content_image_path     String?                  @db.Text
  meta_title             String?                  @db.VarChar(100)
  meta_description       String?                  @db.Text
  meta_keyword           String?                  @db.Text
  page_content           String?                  @db.VarChar(100)
  og_image_path          String?                  @db.Text
  seo_rating             Decimal?                 @db.Decimal(2, 1)
  review_number          Int?
  best_rating            Decimal?                 @db.Decimal(2, 1)
  schema                 String?                  @db.LongText
  website                String                   @default("MYS") @db.VarChar(10)
  status                 Boolean?
  icon_class             String?                  @db.VarChar(255)
  courses_description    String?                  @db.Text
  old_id                 BigInt?                  @db.UnsignedBigInt
  created_at             DateTime                 @default(now()) @db.Timestamp(0)
  updated_at             DateTime                 @default(now()) @updatedAt @db.Timestamp(0)
  contents               CourseCategoryContent[]
  faqs                   CourseCategoryFaq[]
  specializations        CourseSpecialization[]
  legacy_programs        programs[]
  programs               UniversityProgram[]
  university_tution_fees university_tution_fees[]

  @@map("course_categories")
}

model CourseSpecialization {
  id                                BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  name                              String                              @db.VarChar(100)
  slug                              String                              @db.VarChar(100)
  shortnote                         String?                             @db.Text
  duration                          String?                             @db.VarChar(100)
  avrg_salary                       String?                             @db.VarChar(100)
  avrg_fees                         String?                             @db.VarChar(100)
  job_demand                        String?                             @db.VarChar(100)
  author_id                         BigInt?                             @db.UnsignedBigInt
  thumbnail_path                    String?                             @db.Text
  banner_path                       String?                             @db.Text
  content_image_name                String?                             @db.VarChar(200)
  content_image_path                String?                             @db.Text
  meta_title                        String?                             @db.Text
  meta_description                  String?                             @db.LongText
  meta_keyword                      String?                             @db.LongText
  page_content                      String?                             @db.VarChar(100)
  og_image_path                     String?                             @db.Text
  seo_rating                        Int?
  best_rating                       Decimal?                            @db.Decimal(2, 1)
  review_number                     Int?
  course_category_id                BigInt?                             @db.UnsignedBigInt
  status                            Boolean?
  show_on_university                Boolean                             @default(false)
  website                           String?                             @db.VarChar(10)
  icon_class                        String?                             @db.VarChar(100)
  courses_description               String?                             @db.Text
  sg                                String?                             @db.VarChar(100)
  old_id                            BigInt?                             @db.UnsignedBigInt
  thumbnail_name                    Bytes?                              @db.VarBinary(100)
  banner_name                       Bytes?                              @db.VarBinary(100)
  created_at                        DateTime                            @default(now()) @db.Timestamp(0)
  updated_at                        DateTime                            @default(now()) @updatedAt @db.Timestamp(0)
  faqs                              CourseSpecializationFaq[]
  courseCategory                    CourseCategory?                     @relation(fields: [course_category_id], references: [id], onDelete: Cascade, map: "course_specializations_ibfk_1")
  indian_course_specialization_faqs indian_course_specialization_faqs[]
  level_specialization_contents     level_specialization_contents[]
  legacy_programs                   programs[]
  contents                          SpecializationContent[]
  specializationLevels              SpecializationLevel[]
  university_page_specializations   university_page_specializations[]
  programs                          UniversityProgram[]
  university_tution_fees            university_tution_fees[]

  @@index([course_category_id], map: "course_specializations_ibfk_1")
  @@map("course_specializations")
}

model SpecializationLevel {
  id                BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  level             String                       @db.VarChar(255)
  level_slug        String?                      @db.VarChar(255)
  duration          String?                      @db.VarChar(255)
  tuition_fees      String?                      @db.VarChar(255)
  intake            String?                      @db.VarChar(255)
  accreditation     String?                      @db.VarChar(255)
  specialization_id BigInt                       @db.UnsignedBigInt
  created_at        DateTime?                    @db.Timestamp(0)
  updated_at        DateTime?                    @updatedAt @db.Timestamp(0)
  contents          SpecializationLevelContent[]
  specialization    CourseSpecialization         @relation(fields: [specialization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "specialization_levels_specialization_id_foreign")

  @@index([specialization_id], map: "specialization_levels_specialization_id_foreign")
  @@map("specialization_levels")
}

model SpecializationContent {
  id                  BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  website             String               @db.VarChar(10)
  specialization_id   BigInt               @db.UnsignedBigInt
  spc                 String?              @db.VarChar(100)
  tab_id              BigInt?              @db.UnsignedBigInt
  tab                 String               @db.VarChar(100)
  description         String?              @db.LongText
  image_name          String?              @db.VarChar(200)
  image_path          String?              @db.Text
  position            Int?
  status              Boolean              @default(true)
  created_at          DateTime             @default(now()) @db.Timestamp(0)
  updated_at          DateTime             @default(now()) @updatedAt @db.Timestamp(0)
  specialization      CourseSpecialization @relation(fields: [specialization_id], references: [id], onDelete: Cascade, map: "specialization_contents_ibfk_1")
  specialization_tabs specialization_tabs? @relation(fields: [tab_id], references: [id], onUpdate: SetNull, map: "specialization_contents_ibfk_2")

  @@index([specialization_id], map: "sid")
  @@index([tab_id], map: "tab_id")
  @@map("specialization_contents")
}

model SpecializationLevelContent {
  id                      BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  title                   String              @db.VarChar(255)
  slug                    String?             @db.VarChar(255)
  description             String?             @db.LongText
  position                Int?
  specialization_level_id BigInt              @db.UnsignedBigInt
  created_at              DateTime?           @db.Timestamp(0)
  updated_at              DateTime?           @updatedAt @db.Timestamp(0)
  specializationLevel     SpecializationLevel @relation(fields: [specialization_level_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "specialization_level_contents_specialization_level_id_foreign")

  @@index([specialization_level_id], map: "specialization_level_contents_specialization_level_id_foreign")
  @@map("specialization_level_contents")
}

model Level {
  id                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  level               String   @db.VarChar(50)
  slug                String?  @db.VarChar(50)
  short_name          String?  @db.VarChar(100)
  short_name_slug     String?  @db.VarChar(100)
  seo_name            String?  @db.VarChar(100)
  seo_name_slug       String?  @db.VarChar(100)
  courses_description String?  @db.VarChar(255)
  status              Boolean
  created_at          DateTime @default(now()) @db.Timestamp(0)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@map("levels")
}

model Blog {
  id                             BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  created_by                     BigInt?       @db.UnsignedBigInt
  updated_by                     BigInt?       @db.UnsignedBigInt
  approved_by                    BigInt?       @db.UnsignedBigInt
  website                        String        @default("MYS") @db.VarChar(10)
  category_id                    BigInt        @db.UnsignedBigInt
  university_id                  BigInt?       @db.UnsignedBigInt
  author_id                      BigInt?       @db.UnsignedBigInt
  headline                       String?       @db.Text
  slug                           String?       @db.Text
  description                    String?       @db.LongText
  status                         Boolean?
  home_view                      Boolean       @default(false)
  trending                       Boolean       @default(false)
  meta_title                     String?       @db.VarChar(100)
  meta_keyword                   String?       @db.Text
  meta_description               String?       @db.LongText
  page_content                   String?       @db.VarChar(100)
  created_at                     DateTime      @default(now()) @db.Timestamp(0)
  updated_at                     DateTime      @default(now()) @updatedAt @db.Timestamp(0)
  og_image_path                  String?       @db.Text
  seo_rating                     Decimal?      @db.Decimal(2, 1)
  review_number                  Int?
  best_rating                    Decimal?      @db.Decimal(2, 1)
  schema                         String?       @db.LongText
  thumbnail_name                 String?       @db.VarChar(150)
  thumbnail_path                 String?       @db.Text
  contents                       BlogContent[]
  faqs                           BlogFaq[]
  users_blogs_approved_byTousers users?        @relation("blogs_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction, map: "blogs_approved_by_foreign")
  users_blogs_created_byTousers  users?        @relation("blogs_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction, map: "blogs_created_by_foreign")
  category                       BlogCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade, map: "blogs_ibfk_1")
  author                         Author?       @relation(fields: [author_id], references: [id], onDelete: Cascade, map: "blogs_ibfk_2")
  users_blogs_updated_byTousers  users?        @relation("blogs_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction, map: "blogs_updated_by_foreign")

  @@index([author_id], map: "author_id")
  @@index([approved_by], map: "blogs_approved_by_foreign")
  @@index([created_by], map: "blogs_created_by_foreign")
  @@index([updated_by], map: "blogs_updated_by_foreign")
  @@index([category_id], map: "cate_id")
  @@map("blogs")
}

model BlogCategory {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  website          String   @db.VarChar(10)
  category_name    String   @db.VarChar(50)
  category_slug    String   @db.VarChar(50)
  shortnote        String?  @db.LongText
  status           Boolean?
  meta_title       String?  @db.Text
  meta_keyword     String?  @db.LongText
  meta_description String?  @db.LongText
  og_image_path    String?  @db.Text
  page_content     String?  @db.VarChar(100)
  seo_rating       Decimal? @db.Decimal(2, 1)
  best_rating      Decimal? @db.Decimal(2, 1)
  review_number    Int?
  schema           String?  @db.LongText
  created_at       DateTime @default(now()) @db.Timestamp(0)
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamp(0)
  blogs            Blog[]

  @@map("blog_categories")
}

model BlogContent {
  id                  BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  title               String        @db.Text
  slug                String        @db.Text
  description         String        @db.LongText
  image_path          String        @db.Text
  blog_id             BigInt        @db.UnsignedBigInt
  parent_id           BigInt?       @db.UnsignedBigInt
  position            BigInt        @default(1)
  created_at          DateTime?     @db.Timestamp(0)
  updated_at          DateTime?     @updatedAt @db.Timestamp(0)
  blog                Blog          @relation(fields: [blog_id], references: [id], onDelete: Cascade, map: "blog_contents_ibfk_1")
  blog_contents       BlogContent?  @relation("blog_contentsToblog_contents", fields: [parent_id], references: [id], onUpdate: SetNull, map: "blog_contents_ibfk_2")
  other_blog_contents BlogContent[] @relation("blog_contentsToblog_contents")

  @@index([blog_id], map: "blog_id")
  @@index([parent_id], map: "parent_id")
  @@map("blog_contents")
}

model BlogFaq {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  question   String    @db.Text
  answer     String    @db.LongText
  blog_id    BigInt    @db.UnsignedBigInt
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @updatedAt @db.Timestamp(0)
  blog       Blog      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_faqs_blog_id_foreign")

  @@index([blog_id], map: "blog_faqs_blog_id_foreign")
  @@map("blog_faqs")
}

model Author {
  id               BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name             String        @db.VarChar(30)
  slug             String        @db.VarChar(50)
  email            String?       @db.VarChar(50)
  mobile           String?       @db.VarChar(20)
  profile_pic      String?       @db.Text
  profile_pic_path String?       @db.Text
  shortnote        String?       @db.Text
  highlights       String?       @db.LongText
  experiance       String?       @db.LongText
  education        String?       @db.LongText
  status           Boolean       @default(true)
  created_at       DateTime      @default(now()) @db.Timestamp(0)
  updated_at       DateTime      @default(now()) @updatedAt @db.Timestamp(0)
  blogs            Blog[]
  page_contents    PageContent[]

  @@map("authors")
}

model InstituteType {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  website        String   @db.VarChar(20)
  type           String   @db.VarChar(100)
  slug           String   @db.VarChar(100)
  seo_title      String   @db.VarChar(100)
  seo_title_slug String   @db.VarChar(100)
  created_at     DateTime @default(now()) @db.Timestamp(0)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamp(0)
  universities   University[]

  @@map("institute_types")
}

model UniversityOverview {
  id             BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  website        String     @default("MYS") @db.VarChar(10)
